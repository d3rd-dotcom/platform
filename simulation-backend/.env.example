# ============================================================
# Simulation backend env. Copy to .env and fill in.
# The engine refuses to start without LLM_API_KEY and ZEP_API_KEY.
# ============================================================

# ---- Inference (OpenAI-SDK-compatible endpoint) ----
# Using Eliza Cloud (same provider that powers Blue). Eliza is OpenAI-compatible
# at <base>/api/v1, so point LLM_BASE_URL at that path.
#   LLM_API_KEY     = your ELIZA_API_KEY
#   LLM_BASE_URL    = <ELIZA_API_BASE_URL>/api/v1
#   LLM_MODEL_NAME  = a model id Eliza serves (e.g. gemini-2.0-flash)
LLM_API_KEY=your_eliza_api_key
LLM_BASE_URL=https://your-eliza-host/api/v1
LLM_MODEL_NAME=gemini-2.0-flash

# CAVEAT: Eliza Cloud's chat is flaky upstream (elizaOS#7794) and its
# non-streaming path can 500. If simulation runs error out on LLM calls, switch
# these three to DeepSeek (already proven in production for Blue):
#   LLM_API_KEY=<deepseek key>
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL_NAME=deepseek-chat

# ---- Long-term agent memory (REQUIRED) ----
# Free monthly tier is enough to start: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key

# ---- Optional "boost" model for heavy steps ----
# Leave these OUT entirely if unused (do not set to placeholder values).
# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=

# ---- Caller authentication (REQUIRED in production) ----
# Shared secret the Next.js proxy must send in X-Simulation-Secret. Must match
# the app's SIMULATION_API_SECRET. Without it, /api/* is refused unless DEBUG.
# Generate one: `openssl rand -hex 32`.
SIMULATION_API_SECRET=

# Browser origins allowed for CORS (comma-separated). Leave empty: the proxy is
# server-to-server and needs no CORS. Only set this for direct browser testing.
# SIMULATION_ALLOWED_ORIGINS=

# ---- Runtime ----
FLASK_PORT=5001
# Keep OFF in any deployed environment: debug mode exposes a remote code
# execution console. Only set to True for local debugging.
FLASK_DEBUG=False
