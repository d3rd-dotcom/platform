# Mental Wealth Academy - Environment Variables
# Copy this file to .env.local and fill in values

# ============================================
# DATABASE (Required)
# ============================================
DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ============================================
# BLOCKCHAIN - Contract Addresses (Required)
# ============================================
NEXT_PUBLIC_AZURA_KILLSTREAK_ADDRESS=0x2cbb90a761ba64014b811be342b8ef01b471992d
NEXT_PUBLIC_GOVERNANCE_TOKEN_ADDRESS=0x84939fEc50EfdEDC8522917645AAfABFd5b3EA6F
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_PATHWAY_CONTRACT_ADDRESS=0xd116e780Ca9Ec3984e7682e095aaB50006A9c160
NEXT_PUBLIC_AZURA_MARKET_TRADER_ADDRESS=

# ============================================
# BLOCKCHAIN - RPC (Required)
# ============================================
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
BASE_RPC_URL=https://mainnet.base.org

# ============================================
# BLOCKCHAIN - Wallets (Required for on-chain tx)
# ============================================
AZURA_PRIVATE_KEY=
PATHWAY_OWNER_PRIVATE_KEY=

# ============================================
# COINBASE SDK - Azura Wallet (Required for token distribution)
# ============================================
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
AZURA_WALLET_ID=
AZURA_WALLET_SEED=
VOTING_TOKEN_CONTRACT_ADDRESS=
AZURA_TOTAL_TOKEN_POOL=1000000
VOTING_TOKEN_DECIMALS=18

# ============================================
# AI SERVICES (Required)
# ============================================
ELIZA_API_KEY=
ELIZA_API_BASE_URL=https://www.elizacloud.ai
# Blue chat uses Sonnet through Eliza; research mode intentionally uses Opus.
ELIZA_CHAT_MODEL=anthropic/claude-sonnet-4.6
RESEARCH_MODEL=anthropic/claude-opus-4.7
# Blue RAG uses Eliza Cloud embeddings by default via ELIZA_API_KEY.
# Set these only when using a separate OpenAI-compatible embedding provider.
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
BLUE_RAG_AUTO_SEED=1
# Primary survey/test generation provider. If unset or unavailable, test generation falls back to Eliza, then Anthropic, then a local static test.
# Use OPENROUTER_TEST_MODEL=openrouter/free for OpenRouter's free-model router.
OPENROUTER_API_KEY=
OPENROUTER_TEST_MODEL=openrouter/free
# Optional legacy fallback for routes that still call Anthropic directly.
ANTHROPIC_API_KEY=
# Fallback if an Eliza-backed Blue turn fails.
DEEPSEEK_API_KEY=

# ============================================
# AUTH & SECURITY (Required)
# ============================================
INTERNAL_API_SECRET=
CRON_SECRET=
ADMIN_SECRET=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Encrypts custodial agent wallet private keys at rest (AES-256-GCM).
# Required to register platform-managed (custodial) agent accounts.
# Use a long random value, e.g. `openssl rand -hex 32`.
AGENT_KEY_ENCRYPTION_SECRET=

# ============================================
# FARCASTER / NEYNAR (Required for Farcaster auth)
# ============================================
NEYNAR_API_KEY=

# ============================================
# X / TWITTER (Required for X auth)
# ============================================
X_API_KEY=
X_SECRET=
X_BEARER_TOKEN=

# ============================================
# KALSHI TRADING (Required for live Blue routing)
# Official Kalshi auth uses a Key ID plus the RSA private key.
# ============================================
KALSHI_API_BASE_URL=https://api.elections.kalshi.com
KALSHI_API_KEY_ID=
KALSHI_API_PRIVATE_KEY=
VIP_MEMBERSHIP_CARD_ADDRESS=0x5da79055cf8ca6482c997df58822e08e5707d6fc
VIP_MEMBERSHIP_CARD_TOKEN_ID=1

# ============================================
# LEGACY POLYMARKET CLOB (Existing)
# ============================================
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_SECRET=
POLYMARKET_CLOB_PASSPHRASE=
POLYMARKET_WALLET_PRIVATE_KEY=

# ============================================
# OPTIONAL SERVICES
# ============================================
PADLET_API=
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
# Resend — transactional email for event reminders (app/api/events/reminders)
RESEND_API_KEY=
# From address for reminder emails; must be on a Resend-verified domain
EVENTS_FROM_EMAIL=Mental Wealth Academy <research@mentalwealthacademy.net>
CLANKER_API_KEY=
CDP_WEBHOOK_SECRET=
BASESCAN_API_KEY=
NEXT_PUBLIC_ALCHEMY_ID=
SEASON_START_DATE=2026-03-02T00:00:00Z

# ============================================
# APPLE TOKEN (Optional)
# ============================================
APPLE_TOKEN_ADDRESS=
APPLE_UNISWAP_POOL=
AZURA_VAULT_ADDRESS=
APPLE_DEPLOY_BLOCK=0

# ============================================
# SCATTER / NFT (Optional)
# ============================================
NEXT_PUBLIC_SCATTER_COLLECTION_ADDRESS=
NEXT_PUBLIC_SCATTER_CHAIN_ID=8453

# ============================================
# STRIPE - VIP Membership card payments
# ============================================
# Dashboard: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# From `stripe listen` (local) or the webhook endpoint in the Stripe dashboard
STRIPE_WEBHOOK_SECRET=
# Private key of Blue's wallet. This wallet receives direct crypto membership
# payments and signs the gas transaction that sends the membership NFT.
# Falls back to AZURA_PRIVATE_KEY above when BLUE_PRIVATE_KEY is blank.
BLUE_PRIVATE_KEY=
# Crypto checkout: Chainlink ETH/USD aggregator on Base. The default is the
# canonical Base mainnet feed; override only if it changes.
ETH_USD_PRICE_FEED=0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70

# ============================================
# APP URLs
# ============================================
NEXT_PUBLIC_URL=https://mentalwealthacademy.world
NEXT_PUBLIC_APP_URL=https://mentalwealthacademy.world

# ============================================
# SIMULATION ENGINE (Azure World / OASIS backend)
# Deploy simulation-backend/ separately (see its DEPLOY.md).
# The browser never calls the backend directly — requests go through the
# /api/sim-proxy route, which checks VIP membership and adds the shared secret.
# ============================================
# Server-only (NOT NEXT_PUBLIC): the backend host. Never exposed to the browser.
SIMULATION_API_URL=http://localhost:5001
# Shared secret the proxy sends as X-Simulation-Secret. Must match the backend's
# SIMULATION_API_SECRET. Generate one: `openssl rand -hex 32`.
SIMULATION_API_SECRET=
# Local-dev only (ignored in production): skip the membership check on the proxy.
# SIMULATION_DEV_BYPASS=true

# Pinata (IPFS pinning for survey certificate NFTs)
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
